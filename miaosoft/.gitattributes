# Auto detect text files and normalize line endings to LF
* text eol=lf

# Explicitly declare text files
*.sh text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
Makefile text eol=lf
Dockerfile* text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.zip binary
*.tar.gz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary